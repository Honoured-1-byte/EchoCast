# Environment Variables Template

# Copy this file to .env and fill in your actual API keys
# NEVER commit .env with real keys to version control!

# Groq API - For script generation (PRIMARY)
# Get your key at: https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# Deepgram API - For text-to-speech audio generation (OPTIONAL)
# Get your key at: https://console.deepgram.com
# If missing, app falls back to browser TTS
VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here
