# Environment Variables Template

# Copy this file to .env and fill in your actual API keys
# NEVER commit .env with real keys to version control!

# Groq API - For script generation (PRIMARY)
# Get your key at: https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API - For script generation (FALLBACK)
# Get your key at: https://aistudio.google.com
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Deepgram API - For text-to-speech audio generation
# Get your key at: https://console.deepgram.com
VITE_DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs API - For alternative TTS (optional)
# Get your key at: https://elevenlabs.io
VITE_ELEVENLABS_API_KEY=your_elevenlabs_key_here
